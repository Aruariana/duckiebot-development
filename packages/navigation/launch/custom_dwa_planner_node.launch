<?xml version="1.0"?>
<launch>
    <arg name="veh"/>
    <arg name="param_file_name" default="default" doc="Specify a param file. ex:default"/>
    <arg name="pkg_name" default="navigation" doc="name of the package"/>
    <arg name="node_name" default="custom_dwa_planner_node" doc="name of the node"/>

    <group ns="$(arg veh)">
        <node pkg="$(arg pkg_name)" type="$(arg node_name).py" name="$(arg node_name)" output="screen" required="false">
            <param name="veh" value="$(arg veh)"/>
            <rosparam command="load" file="$(find navigation)/config/$(arg node_name)/$(arg param_file_name).yaml"/>
            
            <!-- Remappings: Subscribe to planned path and odometry -->
            <!-- Path comes from graph_search_create_global_path node (global planner) -->
            <remap from="~path_in" to="graph_search_create_global_path/global_path"/>
            <remap from="~odom" to="odometry/filtered"/>
            <remap from="~obstacles" to="obstacle_memory_node/obstacles"/>
            <remap from="~car_cmd" to="lane_controller_node/car_cmd"/>
            
            <!-- Publishers for motion control -->
            <!-- ~car_cmd: duckietown_msgs/Twist2DStamped. Velocity command for motor controller -->
            <!-- ~debug/best_trajectory: visualization_msgs/MarkerArray. Planned trajectory for debugging -->
        </node>
    </group>

</launch>
