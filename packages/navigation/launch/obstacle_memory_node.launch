<?xml version="1.0"?>
<launch>
    <arg name="veh"/>
    <arg name="param_file_name" default="default" doc="Specify a param file. ex:default"/>
    <arg name="pkg_name" default="navigation" doc="name of the package"/>
    <arg name="node_name" default="obstacle_memory_node" doc="name of the node"/>
    <param name="veh" value="$(arg veh)"/>

    <group ns="$(arg veh)">
        <node pkg="$(arg pkg_name)" type="$(arg node_name).py" name="$(arg node_name)" output="screen" required="false">
            <rosparam command="load" file="$(find navigation)/config/$(arg node_name)/$(arg param_file_name).yaml"/>
            
            <!-- Remappings: Subscribe to object detection output -->
            <remap from="~duckie_obstacle_in" to="object_detection_node/duckie_obstacle"/>
            
            <!-- Publishers for visualization and planning -->
            <!-- ~obstacles_markers: visualization_msgs/MarkerArray. RViz visualization of detected obstacles -->
            <!-- ~obstacles: visualization_msgs/MarkerArray. Obstacle data for planner -->
        </node>
    </group>

</launch>
