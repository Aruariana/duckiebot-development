<?xml version="1.0" encoding="utf-8"?>
<launch>
	<arg name="veh" default="$(env VEHICLE_NAME)"/>
    <arg name="demo_name" value="graph_search_move_base"/>
	<arg name="map_name" default="map" />
	
	<!-- start basic args -->
	<include file="$(find duckietown_demos)/launch/master.launch">
	    <!-- Basic arguments -->
		<arg name="veh" value="$(arg veh)"/>
        <arg name="demo_name" value="$(arg demo_name)"/>
		<arg name="param_file_name" value="default" />
	</include>

  	<!-- Set map_name parameter -->
	<param name="/map_name" value="$(arg map_name)" />

  	
  	<!-- Graph search service with move_base -->
  	<node name="graph_search_create_global_path" pkg="navigation" type="graph_search_create_global_path.py" output="screen" ns="$(arg veh)">
    	<param name="map_name" value="$(arg map_name)" />
    	<param name="origin_frame" value="$(arg veh)/map" />
    	<param name="target_frame" value="$(arg veh)/base" />
      <param name="veh" value="$(arg veh)"/>
  	</node>

	<!-- Actions dispatcher for FSM integration -->
	<node name="actions_dispatcher_node" pkg="navigation" type="actions_dispatcher_node.py" output="screen" ns="$(arg veh)">
		<remap from="~fsm_mode" to="fsm_node/mode" />
		<!-- Plan requests come from RQT GUI or mobile app -->
		<!-- Define the topic that publishes SourceTargetNodes -->
		<!-- Example: <remap from="~plan_request" to="navigation_request" /> -->
	</node>

</launch>
