<?xml version="1.0"?>
<launch>
    <arg name="veh"/>
    <arg name="pkg_name" default="object_detection" doc="name of the package"/>
    <arg name="node_name" default="object_detection_node" doc="name of the node"/>

    <group ns="$(arg veh)">
        <node pkg="$(arg pkg_name)" type="$(arg node_name).py" name="$(arg node_name)" output="screen" required="false">
            <param name="veh" value="$(arg veh)"/>
            
            <!-- Remappings: Subscribe to camera topics -->
            <remap from="~camera_info" to="camera_node/camera_info"/>
            <remap from="~image/compressed" to="camera_node/image/compressed"/>
            
            <!-- Publishers for object detection -->
            <!-- ~detected_obstacle: duckiebot_msgs/DetectedObstacle. Detected obstacle for obstacle memory node -->
        </node>
    </group>

</launch>