	<launch>
		<arg name="node_name" default="led_supervisor_node"/>
		<arg name="param_file_name" default="led_supervisor_node"/>
		<arg name="veh" default="$(env VEHICLE_NAME)"/>
		<arg name="pkg_name" default="led_emitter"/>
		<arg name="nodelet_manager_name" default="nodelet_manager"/>
		<arg name="config" default="baseline"/>
		<arg name="param_file_path" default="$(find led_emitter)/config/$(arg node_name)/$(arg param_file_name).yaml"/>
		
		<group ns="$(arg veh)">
			<node pkg="$(arg pkg_name)" type="led_supervisor_node.py"  name="$(arg node_name)" output="screen" >
				<rosparam command="load" file="$(arg param_file_path)"/>
				<remap from="~car_cmd" to="car_cmd_switch_node/cmd"/>
				<remap from="~duckie_obstacle" to="object_detection_node/duckie_obstacle"/>
				<remap from="~set_pattern" to="led_emitter_node/set_pattern"/>
			</node>
		</group>
	</launch>