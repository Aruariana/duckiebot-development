<?xml version="1.0" encoding="utf-8"?>
<launch>
	<arg name="veh" default="$(env VEHICLE_NAME)"/>
    <arg name="demo_name" value="custom_navigation"/>
	<!-- start basic args -->
	<include file="$(find duckietown_demos)/launch/master.launch">
	    <!-- Basic arguments -->
		<arg name="veh" value="$(arg veh)"/>
        <arg name="demo_name" value="$(arg demo_name)"/>
		<arg name="param_file_name" value="default" />

		<!-- Camera and anti instagram -->
		<arg name="anti_instagram" value="true" />

	    <!-- Finite state machine -->
	    <arg name="fsm" value="false"/>

		<!-- Lane Following (disabled - using custom navigation instead) -->
		<arg name="lane_following" value="false"/>

		<!-- Custom Navigation Stack -->
		<arg name="custom_navigation" value="true"/>

	    <!-- Object Detection (required for custom navigation) -->
	    <arg name="object_detection" value="true"/>

		<!-- Apriltag Localization-->
		<arg name="apriltags" value="true"/>

  	</include>

</launch>
