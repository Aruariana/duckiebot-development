<?xml version="1.0" encoding="utf-8"?>
<launch>
    <arg name="veh" default="$(env VEHICLE_NAME)"/>
    <arg name="param_file_name" default="default"/>
    <arg name="demo_name" default="manual_with_leds"/>

    <include file="$(find duckietown_demos)/launch/master.launch">
        <arg name="veh" value="$(arg veh)"/>
        <arg name="demo_name" value="$(arg demo_name)"/>
        <arg name="param_file_name" value="$(arg param_file_name)"/>
        <arg name="LED" value="true"/>
        <arg name="/LED/emitter" value="true"/>
        <arg name="object_detection" value="true"/>
    </include>

    <include file="$(find led_emitter)/launch/led_supervisor_node.launch">
        <arg name="veh" value="$(arg veh)"/>
    </include>
</launch>
